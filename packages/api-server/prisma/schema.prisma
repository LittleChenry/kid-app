generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Practice {
  id        String   @id @default(cuid())
  grade     Int
  score     Float
  totalTime Int
  problems  String
  results   String
  createdAt DateTime @default(now())
}

model PracticeSession {
  id          String          @id @default(cuid())
  difficulty  Int
  score       Float
  totalChars  Int
  createdAt   DateTime        @default(now())
  records     WritingRecord[]
}

model WritingRecord {
  id              String          @id @default(cuid())
  sessionId       String
  character       String
  handwritingData String
  score           Float
  feedback        String
  session         PracticeSession @relation(fields: [sessionId], references: [id])
  createdAt       DateTime        @default(now())
}

model Character {
  id              String   @id @default(cuid())
  char            String   @unique
  pinyin          String
  strokes         Int
  difficulty      Int
  grade           Int
  radical         String?
  definition      String?
  examples        String?
  decomposition   String?
  hanziWriterData String?
  createdAt       DateTime @default(now())
}

model Video {
  id          String   @id @default(cuid())
  title       String
  fileName    String
  filePath    String?
  format      String
  size        BigInt
  duration    Float
  status      String   @default("ready")
  hlsUrl      String?
  thumbnailUrl String?
  category    String?
  createdAt   DateTime @default(now())
}
